									"    pm.expect(jsonData).to.have.property('version');",
									"    pm.expect(jsonData).to.have.property('endpoints_implemented');",
									"});",
									"",
									"pm.test('All endpoints are active', function () {",
									"    const jsonData = pm.response.json();",
									"    const endpoints = jsonData.endpoints_implemented;",
